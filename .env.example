# Orion Agent Platform — Environment Configuration

# App
ORION_APP_NAME=Orion Agent Platform
ORION_DEBUG=false
ORION_HOST=0.0.0.0
ORION_PORT=8000

# Temporal
ORION_TEMPORAL_HOST=localhost
ORION_TEMPORAL_PORT=7233
ORION_TEMPORAL_NAMESPACE=default
ORION_TEMPORAL_TASK_QUEUE=orion-task-queue

# PostgreSQL
ORION_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/orion

# Redis
ORION_REDIS_URL=redis://localhost:6379/0
ORION_REDIS_STREAM_CHANNEL=orion:streams

# Security
ORION_API_KEY=
ORION_JWT_SECRET=

# Observability
ORION_OTEL_ENDPOINT=
ORION_OTEL_SERVICE_NAME=orion-platform

# Retry defaults
ORION_DEFAULT_MAX_RETRIES=3
ORION_DEFAULT_RETRY_BACKOFF=1.0
ORION_DEFAULT_RETRY_MAX_WAIT=30
